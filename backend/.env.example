APP_ENV=dev
APP_SECRET=change_me_growth_mvp_secret_key_32chars

# Docker: host must be "mysql", not 127.0.0.1
DATABASE_URL="mysql://root:password@mysql:3306/growth_mvp?serverVersion=8.0&charset=utf8mb4"
MEMCACHED_DSN=memcached://memcached:11211

TELEGRAM_MOCK=true
TELEGRAM_TOKEN_ENCRYPTION_KEY=c2VjcmV0LWtleS0zMi1ieXRlcy1sb25nISEh

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=growth_mvp_jwt_pass

CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1|growth-mvp\.vedicai\.ru)(:[0-9]+)?$
